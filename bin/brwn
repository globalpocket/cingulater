#!/usr/bin/env python3
import os
import sys

# プロジェクトルートの .venv を優先的に読み込む
base_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
venv_site_packages = os.path.join(
    base_dir,
    ".venv",
    "lib",
    f"python{sys.version_info.major}.{sys.version_info.minor}",
    "site-packages",
)
if os.path.exists(venv_site_packages):
    sys.path.insert(0, venv_site_packages)
sys.path.insert(0, base_dir)

import subprocess  # noqa: E402
import time  # noqa: E402
import signal  # noqa: E402
import argparse  # noqa: E402
import requests  # noqa: E402

# Build info
BUILD_ID = "2026.04.21.DR"


def get_running_engine_pid():
    """LSOFでポート8137を使用しているPIDを取得"""
    try:
        output = subprocess.check_output(["lsof", "-t", "-i", ":8137"]).decode().strip()
        if output:
            return int(output.split("\n")[0])
    except Exception:
        pass
    return None


def is_engine_running(port=8137):
    import socket

    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        return s.connect_ex(("localhost", port)) == 0


def ensure_llm_servers_started():
    try:
        from src.core.config import get_settings
        from src.mcp.llm_launcher import launch_llm_server, check_llm_status
        from urllib.parse import urlparse

        base_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
        config_path = os.path.join(base_dir, "config", "config.yaml")
        settings = get_settings(config_path)

        # Interlocutor
        inter_url = urlparse(settings.llm.interlocutor_endpoint)
        inter_port = inter_url.port or 8080
        inter_model = settings.llm.models.get("interlocutor")

        # Coder
        coder_url = urlparse(settings.llm.coder_endpoint)
        coder_port = coder_url.port or 8081
        coder_model = settings.llm.models.get("coder")

        servers_to_check = [
            (inter_port, inter_model, "Interlocutor"),
            (coder_port, coder_model, "Coder"),
        ]

        for port, model, name in servers_to_check:
            if model and port:
                if not check_llm_status(port):
                    print(f"🚀 Starting {name} LLM Server ({model}) on port {port}...")
                    res = launch_llm_server(model, port)
                    print(f"  -> {res}")
                else:
                    print(f"✅ {name} LLM Server is already running on port {port}.")
    except Exception as e:
        print(f"⚠️ Could not verify/start LLM servers: {e}")


def ensure_engine_started():
    ensure_llm_servers_started()

    if is_engine_running():
        return True

    print("🚀 Starting Brownie Engine in background...")
    base_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    venv_python = os.path.join(base_dir, ".venv", "bin", "python")

    # PYTHONPATHをベースディレクトリに設定してModuleNotFoundErrorを回避
    env = os.environ.copy()
    env["PYTHONPATH"] = base_dir + (
        os.pathsep + env.get("PYTHONPATH", "") if env.get("PYTHONPATH") else ""
    )

    # ログディレクトリの確保
    os.makedirs(os.path.join(base_dir, "logs"), exist_ok=True)
    log_file_path = os.path.join(base_dir, "logs", "engine.log")
    log_file = open(log_file_path, "a")

    subprocess.Popen(
        [venv_python, "src/api/server.py"],
        stdout=log_file,
        stderr=log_file,
        env=env,
        start_new_session=True,
        cwd=base_dir,
    )

    # 起動（ポート有効化）を待機
    for _ in range(45):
        if is_engine_running():
            print("✅ Engine is online.")
            return True
        time.sleep(1)
    print(f"❌ Failed to start engine. Check {log_file_path}")
    return False


def run_command(args):
    base_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    venv_python = os.path.join(base_dir, ".venv", "bin", "python")

    if args.action == "stop":
        pid = get_running_engine_pid()
        if pid:
            print(f"🛑 Stopping Brownie Engine (PID: {pid})...")
            os.kill(pid, signal.SIGTERM)
        else:
            print("Engine is not running.")
        return

    if args.action == "start":
        ensure_engine_started()
        return

    if args.action == "status":
        pid = get_running_engine_pid()
        if pid:
            print(f"Brownie Engine: ACTIVE (PID: {pid}, http://localhost:8137)")
        else:
            print("Brownie Engine: STOPPED")
        return

    # 通常の対話・指示実行フロー
    if not ensure_engine_started():
        sys.exit(1)

    if args.action is None:
        try:
            subprocess.run([venv_python, "src/interfaces/cli.py"])
        except KeyboardInterrupt:
            print("\nDetached from interaction. Engine remains running.")
        return
    elif args.action == "run":
        prompt = " ".join(args.remainder)
        try:
            res = requests.post(
                "http://localhost:8137/v1/chat/completions",
                json={
                    "model": "brownie-v2",
                    "messages": [{"role": "user", "content": prompt}],
                },
                timeout=300,
            )
            if res.status_code == 200:
                print(res.json()["choices"][0]["message"]["content"])
            else:
                print(f"Error: Engine returned {res.status_code}")
        except Exception as e:
            print(f"Connection Error: {e}")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Brownie CLI")
    parser.add_argument(
        "action", nargs="?", help="Action (chat, start, stop, etc.) or just a prompt"
    )
    parser.add_argument("remainder", nargs=argparse.REMAINDER)
    args = parser.parse_args()

    known_actions = ["start", "stop", "status", "reset", "run"]
    if not args.action:
        # 引数なし：対話モード
        pass
    elif args.action not in known_actions:
        # アクションが定義外：すべてをプロンプト（単発実行）として扱う
        args.remainder = [args.action] + args.remainder
        args.action = "run"

    run_command(args)
