{
  "mcpServers": {
    "mlx-launcher": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/globalpocket/mcp-mlx-launcher.git",
        "mcp-mlx-launcher"
      ]
    },
    "mcp-reranker": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/globalpocket/mcp-reranker.git",
        "mcp-reranker"
      ],
      "env": {
        "RERANKER_MODEL_NAME": "BAAI/bge-reranker-v2-m3"
      }
    },
    "mcp-routing-gateway": {
      "command": "mcp-routing-gateway",
      "args": [
        "--work-dir",
        ".",
        "--config",
        "gateway_config.json",
        "--mcp-config",
        "mcp_config.json"
      ]
    },
    "docker": {
      "command": "uvx",
      "args": ["mcp-server-docker"]
    }
  }
}
