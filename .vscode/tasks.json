{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Omni Background Analyzer",
            "type": "shell",
            "command": "node",
            "args": [
                ".agents/scripts/monitor.js"
            ],
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": [
                {
                    "pattern": {
                        "regexp": "^$"
                    },
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^.*Starting setup",
                        "endsPattern": "^.*Watcher is ready"
                    }
                }
            ],
            "presentation": {
                "reveal": "never",
                "panel": "dedicated"
            }
        }
    ]
}
