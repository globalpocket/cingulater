{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Omni Background Analyzer",
            "type": "shell",
            "command": "node",
            "args": [
                ".agents/scripts/monitor.js"
            ],
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": [
                {
                    "owner": "analyzer",
                    "pattern": [],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^\\[Analyzer\\] Analysis started",
                        "endsPattern": "^\\[Analyzer\\] Analysis finished"
                    }
                }
            ],
            "presentation": {
                "reveal": "never",
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            }
        }
    ]
}
