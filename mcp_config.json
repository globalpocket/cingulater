{
  "mcpServers": {
    "mcp-routing-gateway": {
      "command": "mcp-gateway",
      "args": [
        "--work-dir", ".",
        "--config", "gateway_config.json",
        "--mcp-config", "gateway_mcp_config.json"
      ]
    },
    "docker": {
      "command": "uvx",
      "args": [
        "mcp-server-docker"
      ]
    }
  }
}