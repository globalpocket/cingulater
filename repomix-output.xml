        self.pm = pluggy.PluginManager("brownie")
        self.pm.add_hookspecs(MCPPluginSpec)

        # デフォルトのプラグイン発見器を登録
        self.pm.register(DirectoryDiscoveryPlugin(project_root))

    # --- Properties (Client accessors) ---
    @property
    def workspace_client(self) -> Optional[Client]:
        return self.clients.get("workspace")

    @property
    def knowledge_client(self) -> Optional[Client]:
        return self.clients.get("knowledge")

    @property
    def resource_monitor_client(self) -> Optional[Client]:
